# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO
TIMEZONE=America/Chicago

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aurum_commerce
POSTGRES_USER=aurum
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://aurum:changeme@localhost:5432/aurum_commerce

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ChromaDB (Vector Store) ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_BUSINESS_MEMORY=business_memory
CHROMA_COLLECTION_PRODUCTS=products
CHROMA_COLLECTION_CREATIVES=creatives

# ── Local LLM (DGX Spark / Ollama) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:70b
OLLAMA_FAST_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Cloud LLM (fallback only) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_PREFER_LOCAL=true
LLM_MAX_LOCAL_RETRIES=3

# ── Shopify ──────────────────────────────────────────────────────────────────
# Comma-separated JSON: [{"store":"mystore.myshopify.com","api_key":"..","api_secret":"..","access_token":".."}]
SHOPIFY_STORES=[]
SHOPIFY_API_VERSION=2025-01

# ── Meta (Facebook/Instagram) ────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Google ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
SERPAPI_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_RECIPIENTS=torylivas@gmail.com

# ── Tandem Browser ───────────────────────────────────────────────────────────
TANDEM_WS_URL=ws://localhost:9222
TANDEM_TIMEOUT=30

# ── Business Rules ───────────────────────────────────────────────────────────
MIN_GROSS_MARGIN=0.40
MIN_OPPORTUNITY_SCORE=60
MIN_CONFIDENCE_SCORE=65
MAX_SHIPPING_DAYS=15
MIN_SUPPLIER_RATING=4.0
PRICE_CHANGE_APPROVAL_THRESHOLD=0.15
AD_SPEND_APPROVAL_THRESHOLD=100.00

# ── Executive Brief ──────────────────────────────────────────────────────────
BRIEF_SCHEDULE_CRON=0 7 * * *
BRIEF_TIMEZONE=America/Chicago
